rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ───────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
        && (request.auth.token.email == 'anilkumardevarakonda03@gmail.com'
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'fullName', 'displayName', 'name', 'bio', 'role', 'location',
            'photoUrl', 'photoURL', 'introVideoLink',
            'portfolio1', 'portfolio2', 'portfolio3',
            'portfolioPhotos', 'portfolioMedia',
            'availabilityStatus', 'lookingFor', 'profileTags',
            'instagramLink', 'youtubeLink',
            'ageRange', 'height', 'bodyType',
            'isOnline', 'lastSeen', 'fcmToken', 'platform',
            'updatedAt'
          ])) || isAdmin();

      match /followers/{followerId} {
        allow read: if isLoggedIn();
        allow create, delete: if isLoggedIn();
      }

      match /following/{followingId} {
        allow read: if isLoggedIn();
        allow create, delete: if isLoggedIn();
      }
    }

    // ── Premium fields – server-write only ──────────────────────────────────
    // These are enforced: client MUST NOT write premiumTier/premiumExpiry etc.
    // (already covered by the field whitelist above)

    // ── Payments ──────────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Subscriptions ────────────────────────────────────────────────────────
    match /subscriptions/{subId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin(); // server-write only
    }

    // ── Connections ──────────────────────────────────────────────────────────
    match /connections/{connId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow delete: if isLoggedIn();
    }

    // ── Chats ────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isLoggedIn() && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && resource.data.participants.hasAny([request.auth.uid]);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isLoggedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);
        allow create: if isLoggedIn() && request.resource.data.senderId == request.auth.uid;
        allow update: if isLoggedIn() && request.resource.data.senderId == request.auth.uid;
        allow delete: if isLoggedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    // ── Auditions ────────────────────────────────────────────────────────────
    match /auditions/{auditionId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (resource.data.postedById == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      match /applications/{appId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      }

      match /comments/{commentId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isLoggedIn() && resource.data.userId == request.auth.uid;
      }

      match /likes/{likeId} {
        allow read: if isLoggedIn();
        allow create, delete: if isLoggedIn();
      }

      match /saved/{savedId} {
        allow read, create, delete: if isLoggedIn() && request.auth.uid == savedId;
      }
    }

    // ── Films ────────────────────────────────────────────────────────────────
    match /films/{filmId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      match /comments/{commentId} { allow read, create, delete: if isLoggedIn(); }
      match /likes/{likeId} { allow read, create, delete: if isLoggedIn(); }
    }

    // ── Contests ─────────────────────────────────────────────────────────────
    match /contests/{contestId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      match /entries/{entryId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      }
    }

    // ── Contest Entries ──────────────────────────────────────────────────────
    match /contestEntries/{entryId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isLoggedIn() && resource.data.userId == request.auth.uid;
    }

    // ── Feed Posts ───────────────────────────────────────────────────────────
    match /feedPosts/{postId} {
      allow read: if isLoggedIn();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Reports ──────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // ── Verification Requests ────────────────────────────────────────────────
    match /verificationRequests/{reqId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Casting Requests ─────────────────────────────────────────────────────
    match /castingRequests/{reqId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Banned Users ─────────────────────────────────────────────────────────
    match /bannedUsers/{userId} {
      allow read: if isAdmin();
      allow create, delete: if isAdmin();
    }

    // ── Reels ────────────────────────────────────────────────────────────────
    match /reels/{reelId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();

      match /comments/{commentId} { allow read, create, delete: if isLoggedIn(); }
      match /likes/{likeId} { allow read, create, delete: if isLoggedIn(); }
    }

    // ── Projects / Rooms ─────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Config (server-managed, read-only for clients) ──────────────────────
    match /config/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── Spotlight / Premium Screens ─────────────────────────────────────────
    match /premiumContent/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── Push Notifications (legacy — locked down) ───────────────────────────
    match /pushNotifications/{notifId} {
      allow read, write: if false;
    }

    // ── Connection Requests ─────────────────────────────────────────────────
    match /connectionRequests/{reqId} {
      allow read: if isLoggedIn() && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow create: if isLoggedIn() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.toUserId == request.auth.uid;
      allow delete: if isLoggedIn() && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
    }

    // ── Saved Auditions (top-level) ─────────────────────────────────────────
    match /savedAuditions/{savedId} {
      allow read, delete: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
    }

    // ── Events ──────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isLoggedIn();
      allow create, update, delete: if isAdmin();
    }

    // ── Groups ──────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && resource.data.createdBy == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Call Rooms ──────────────────────────────────────────────────────────
    match /callRooms/{roomId} {
      allow read: if isLoggedIn() && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if isLoggedIn();
      allow update: if isLoggedIn() && resource.data.participants.hasAny([request.auth.uid]);
    }

    // ── Showreels ───────────────────────────────────────────────────────────
    match /showreels/{showreelId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Catch-all: Deny everything else ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
